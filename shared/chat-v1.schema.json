{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://darktableagent.local/schemas/chat-v1.schema.json",
  "title": "darktableAgent Chat v3.0 Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "session",
    "message",
    "refinement",
    "uiContext",
    "capabilityManifest",
    "imageSnapshot"
  ],
  "properties": {
    "schemaVersion": {
      "const": "3.0"
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appSessionId",
        "imageSessionId",
        "conversationId",
        "turnId"
      ],
      "properties": {
        "appSessionId": {
          "type": "string",
          "minLength": 1
        },
        "imageSessionId": {
          "type": "string",
          "minLength": 1
        },
        "conversationId": {
          "type": "string",
          "minLength": 1
        },
        "turnId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "text"
      ],
      "properties": {
        "role": {
          "const": "user"
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "refinement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "enabled",
        "maxPasses",
        "passIndex",
        "automaticContinuation",
        "goalText"
      ],
      "properties": {
        "mode": {
          "enum": [
            "single-turn",
            "multi-turn"
          ]
        },
        "enabled": {
          "type": "boolean"
        },
        "maxPasses": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "passIndex": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "automaticContinuation": {
          "type": "boolean"
        },
        "goalText": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "uiContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view",
        "imageId",
        "imageName"
      ],
      "properties": {
        "view": {
          "type": "string",
          "minLength": 1
        },
        "imageId": {
          "type": [
            "integer",
            "null"
          ]
        },
        "imageName": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "capabilityManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifestVersion",
        "targets"
      ],
      "properties": {
        "manifestVersion": {
          "type": "string",
          "minLength": 1
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "capabilityId",
              "label",
              "kind",
              "targetType",
              "actionPath",
              "supportedModes",
              "minNumber",
              "maxNumber",
              "defaultNumber",
              "stepNumber"
            ],
            "properties": {
              "capabilityId": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "const": "set-float"
              },
              "targetType": {
                "const": "darktable-action"
              },
              "actionPath": {
                "type": "string",
                "minLength": 1
              },
              "supportedModes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "enum": [
                    "delta",
                    "set"
                  ]
                }
              },
              "minNumber": {
                "type": "number"
              },
              "maxNumber": {
                "type": "number"
              },
              "defaultNumber": {
                "type": "number"
              },
              "stepNumber": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "imageSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "imageRevisionId",
        "metadata",
        "historyPosition",
        "historyCount",
        "editableSettings",
        "history",
        "preview",
        "histogram"
      ],
      "properties": {
        "imageRevisionId": {
          "type": "string",
          "minLength": 1
        },
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "imageId",
            "imageName",
            "cameraMaker",
            "cameraModel",
            "width",
            "height",
            "exifExposureSeconds",
            "exifAperture",
            "exifIso",
            "exifFocalLength"
          ],
          "properties": {
            "imageId": {
              "type": [
                "integer",
                "null"
              ]
            },
            "imageName": {
              "type": [
                "string",
                "null"
              ]
            },
            "cameraMaker": {
              "type": [
                "string",
                "null"
              ]
            },
            "cameraModel": {
              "type": [
                "string",
                "null"
              ]
            },
            "width": {
              "type": "integer"
            },
            "height": {
              "type": "integer"
            },
            "exifExposureSeconds": {
              "type": "number"
            },
            "exifAperture": {
              "type": "number"
            },
            "exifIso": {
              "type": "number"
            },
            "exifFocalLength": {
              "type": "number"
            }
          }
        },
        "historyPosition": {
          "type": "integer"
        },
        "historyCount": {
          "type": "integer"
        },
        "editableSettings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "settingId",
              "capabilityId",
              "label",
              "actionPath",
              "currentNumber",
              "supportedModes",
              "minNumber",
              "maxNumber",
              "defaultNumber",
              "stepNumber"
            ],
            "properties": {
              "settingId": {
                "type": "string",
                "minLength": 1
              },
              "capabilityId": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "actionPath": {
                "type": "string",
                "minLength": 1
              },
              "currentNumber": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "supportedModes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "enum": [
                    "delta",
                    "set"
                  ]
                }
              },
              "minNumber": {
                "type": "number"
              },
              "maxNumber": {
                "type": "number"
              },
              "defaultNumber": {
                "type": "number"
              },
              "stepNumber": {
                "type": "number"
              }
            }
          }
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "num",
              "module",
              "enabled",
              "multiPriority",
              "instanceName",
              "iopOrder"
            ],
            "properties": {
              "num": {
                "type": "integer"
              },
              "module": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "enabled": {
                "type": "boolean"
              },
              "multiPriority": {
                "type": "integer"
              },
              "instanceName": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "iopOrder": {
                "type": "integer"
              }
            }
          }
        },
        "preview": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "previewId",
            "mimeType",
            "width",
            "height",
            "base64Data"
          ],
          "properties": {
            "previewId": {
              "type": "string",
              "minLength": 1
            },
            "mimeType": {
              "type": "string",
              "minLength": 1
            },
            "width": {
              "type": "integer"
            },
            "height": {
              "type": "integer"
            },
            "base64Data": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "histogram": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "binCount",
            "channels"
          ],
          "properties": {
            "binCount": {
              "type": "integer"
            },
            "channels": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "bins"
                ],
                "properties": {
                  "bins": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
