{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://darktableagent.local/schemas/chat-v1.schema.json",
  "title": "darktableAgent Chat v2.0 Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "conversationId",
    "message",
    "uiContext",
    "imageState",
    "mockResponseId"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "conversationId": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "text"
      ],
      "properties": {
        "role": {
          "const": "user"
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "uiContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "view",
        "imageId",
        "imageName"
      ],
      "properties": {
        "view": {
          "type": "string",
          "minLength": 1
        },
        "imageId": {
          "type": [
            "integer",
            "null"
          ]
        },
        "imageName": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "imageState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currentExposure",
        "historyPosition",
        "historyCount",
        "metadata",
        "controls",
        "history"
      ],
      "properties": {
        "currentExposure": {
          "type": [
            "number",
            "null"
          ]
        },
        "historyPosition": {
          "type": "integer"
        },
        "historyCount": {
          "type": "integer"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "imageId",
            "imageName",
            "cameraMaker",
            "cameraModel",
            "width",
            "height",
            "exifExposureSeconds",
            "exifAperture",
            "exifIso",
            "exifFocalLength"
          ],
          "properties": {
            "imageId": { "type": ["integer", "null"] },
            "imageName": { "type": ["string", "null"] },
            "cameraMaker": { "type": ["string", "null"] },
            "cameraModel": { "type": ["string", "null"] },
            "width": { "type": "integer" },
            "height": { "type": "integer" },
            "exifExposureSeconds": { "type": "number" },
            "exifAperture": { "type": "number" },
            "exifIso": { "type": "number" },
            "exifFocalLength": { "type": "number" }
          }
        },
        "controls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["capabilityId", "label", "actionPath", "currentNumber"],
            "properties": {
              "capabilityId": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "actionPath": { "type": "string", "minLength": 1 },
              "currentNumber": { "type": ["number", "null"] }
            }
          }
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "num",
              "module",
              "enabled",
              "multiPriority",
              "instanceName",
              "iopOrder"
            ],
            "properties": {
              "num": { "type": "integer" },
              "module": { "type": ["string", "null"] },
              "enabled": { "type": "boolean" },
              "multiPriority": { "type": "integer" },
              "instanceName": { "type": ["string", "null"] },
              "iopOrder": { "type": "integer" }
            }
          }
        }
      }
    },
    "mockResponseId": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
